<!DOCTYPE html>
<html>
    <head>
        <title><%= role === "admin" ? "Admin Signup" : "Employee Signup" %></title>
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>
        <div class="nav">
            <p>Employee Payroll</p>
        </div>
        <div class="container">
            <div class="card form-card">
                <h1><%= role === "admin" ? "Admin Signup" : "Employee Signup" %></h1>
                <form class="employee-form" action="<%= role === 'admin' ? '/admin/signup' : '/employee/signup' %>" method="post">
                    <div class="grid">
                        <div>
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" required />
                        </div>
                        <div>
                            <label for="email">Email</label>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                <% if (role === "admin") { %>
                                    pattern="^[^\s@]+@admin\.com$"
                                    title="Admin email must end with @admin.com"
                                <% } %>
                                required
                            />
                        </div>
                        <div>
                            <label for="password">Password</label>
                            <input type="text" id="password" name="password" minlength="4" maxlength="6" required />
                        </div>
                        <% if (role !== "admin") { %>
                            <div>
                                <label for="department">Department</label>
                                <input type="text" id="department" name="department" required />
                            </div>
                        <% } %>
                        <div>
                            <label for="basic_salary">Basic Salary</label>
                            <input type="number" id="basic_salary" name="basic_salary" required />
                        </div>
                    </div>
                    <div class="form-actions">
                        <div class="left">
                            <a href="<%= role === 'admin' ? '/employee/signup' : '/admin/signup' %>" class="btn-secondary btn-cancel">
                                Switch to <%= role === "admin" ? "Employee" : "Admin" %>
                            </a>
                        </div>
                        <div class="right">
                            <a href="<%= role === 'admin' ? '/admin/login' : '/employee/login' %>" class="btn-secondary">Have Account</a>
                            <button type="submit" class="btn-primary btn-success">Signup</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </body>
</html>
